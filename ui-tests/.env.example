# Credentials for an EXISTING CMS administrator on the sample site.
#
# The sample (Sample/OptimizelyTwelveTest) uses RegisterAdminUserBehaviors.Enabled,
# so on a fresh database no admin exists yet. Complete the one-time first-run
# registration in a browser (see README), then put those credentials here.
#
# Copy this file to ".env" and fill in the password.
ADMIN_USERNAME=admin@example.com
ADMIN_PASSWORD=

# The hosting environment name to test environment-level robots overrides against.
# The sample runs as Development (ASPNETCORE_ENVIRONMENT=Development).
ENVIRONMENT_NAME=Development
