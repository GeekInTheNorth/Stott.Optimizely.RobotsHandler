{
  "name": "stott-robotshandler-ui-tests",
  "version": "1.0.0",
  "private": true,
  "description": "Playwright UI tests that drive the Robots Handler admin UI and verify robots.txt routing across the sample site's frontend and editor domains.",
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:ui": "playwright test --ui",
    "report": "playwright show-report",
    "install-browsers": "playwright install chromium"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@types/node": "^22.0.0",
    "dotenv": "^16.4.5",
    "typescript": "^5.6.0"
  },
  "volta": {
    "node": "24.15.0"
  }
}
